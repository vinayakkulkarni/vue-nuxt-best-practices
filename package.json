{
  "name": "vue-nuxt-best-practices",
  "version": "1.8.0",
  "private": true,
  "description": "Vue and Nuxt skills for Claude Code and AI agents. Reactivity, component performance, data fetching, SSR patterns, and full-stack best practices.",
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter './skills/*' run build",
    "build:vue": "pnpm --filter vue-best-practices run build",
    "build:nuxt": "pnpm --filter nuxt-best-practices run build",
    "build:seo": "pnpm --filter nuxt-seo-best-practices run build",
    "build:geo": "pnpm --filter nuxt-geo-best-practices run build",
    "build:agent-ready": "pnpm --filter nuxt-agent-ready-best-practices run build",
    "validate": "pnpm --filter './skills/*' run validate",
    "validate:vue": "pnpm --filter vue-best-practices run validate",
    "validate:nuxt": "pnpm --filter nuxt-best-practices run validate",
    "validate:seo": "pnpm --filter nuxt-seo-best-practices run validate",
    "validate:geo": "pnpm --filter nuxt-geo-best-practices run validate",
    "validate:agent-ready": "pnpm --filter nuxt-agent-ready-best-practices run validate",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.11.0"
    }
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
