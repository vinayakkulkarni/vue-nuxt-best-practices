{
  "name": "vue-nuxt-best-practices",
  "version": "1.5.1",
  "description": "Vue and Nuxt skills for Claude Code and AI agents. Reactivity, component performance, data fetching, SSR patterns, and full-stack best practices.",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "license": "MIT",
  "private": true,
  "workspaces": [
    "skills/*"
  ],
  "scripts": {
    "build": "bun run build:vue && bun run build:nuxt && bun run build:seo && bun run build:geo && bun run build:agent-ready",
    "build:vue": "bun run --cwd skills/vue-best-practices build",
    "build:nuxt": "bun run --cwd skills/nuxt-best-practices build",
    "build:seo": "bun run --cwd skills/nuxt-seo-best-practices build",
    "build:geo": "bun run --cwd skills/nuxt-geo-best-practices build",
    "build:agent-ready": "bun run --cwd skills/nuxt-agent-ready-best-practices build",
    "validate": "bun run validate:vue && bun run validate:nuxt && bun run validate:seo && bun run validate:geo && bun run validate:agent-ready",
    "validate:vue": "bun run --cwd skills/vue-best-practices validate",
    "validate:nuxt": "bun run --cwd skills/nuxt-best-practices validate",
    "validate:seo": "bun run --cwd skills/nuxt-seo-best-practices validate",
    "validate:geo": "bun run --cwd skills/nuxt-geo-best-practices validate",
    "validate:agent-ready": "bun run --cwd skills/nuxt-agent-ready-best-practices validate",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
